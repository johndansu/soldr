# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Encryption — generate with: openssl rand -base64 32
ENCRYPTION_SECRET=

# Resend — email sending: https://resend.com (free: 3,000 emails/month)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# AI Provider — switch between 'openrouter' (dev/free) and 'anthropic' (prod/BYOK)
AI_PROVIDER=openrouter

# OpenRouter — free tier, no credit card needed: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Embeddings (choose one — only needed for Phase 2 client memory)
# VOYAGE_API_KEY=
# OPENAI_API_KEY=

# Cron job secret — set any random string, add the same value in Vercel env vars
CRON_SECRET=
